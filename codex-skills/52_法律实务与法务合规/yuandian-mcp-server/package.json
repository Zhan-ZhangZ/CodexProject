{
    "name": "yuandian-mcp-server",
    "version": "0.1.3",
    "description": "MCP server for YuanDian open platform APIs",
    "license": "MIT",
    "type": "module",
    "bin": {
        "yuandian-mcp-server": "build/index.js"
    },
    "files": [
        "build"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "corepack pnpm --filter @modelcontextprotocol/server build && tsc && chmod 755 build/index.js",
        "dev": "corepack pnpm --filter @modelcontextprotocol/server build && tsx src/index.ts",
        "prepack": "corepack pnpm run build",
        "smoke": "corepack pnpm run build && tsx scripts/smoke-test.ts",
        "start": "node build/index.js",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@cfworker/json-schema": "^4.1.1",
        "@modelcontextprotocol/server": "^2.0.0-alpha.2",
        "zod": "^4.2.0"
    },
    "devDependencies": {
        "@types/node": "^24.10.1",
        "tsx": "^4.16.5",
        "typescript": "^5.9.3"
    }
}
