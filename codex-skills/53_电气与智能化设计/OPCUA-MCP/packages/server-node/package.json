{
  "name": "opcua-mcp-server",
  "version": "0.1.2",
  "description": "MCP server for OPC UA control - Model Context Protocol server for OPC UA operations",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "opcua-mcp-server": "./build/index.js",
    "opcua-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-contract.mjs",
    "watch": "tsc --watch",
    "start": "node build/index.js",
    "dev": "tsc && node build/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "opcua",
    "opc-ua",
    "industrial",
    "automation",
    "scada"
  ],
  "author": "Midhun Xavier",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/midhunxavier/OPCUA-MCP.git",
    "directory": "packages/server-node"
  },
  "homepage": "https://github.com/midhunxavier/OPCUA-MCP#readme",
  "bugs": {
    "url": "https://github.com/midhunxavier/OPCUA-MCP/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "node-opcua": "^2.128.0",
    "node-opcua-client": "^2.128.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "build/**/*",
    "README.md"
  ]
} 